# ─── Backend ──────────────────────────────────────────────────────
# Ruta de la base de datos SQLite (dentro del contenedor)
DATABASE_URL=sqlite:////app/data/fichajes.db

# Ruta del fichero Excel generado (dentro del contenedor)
EXCEL_PATH=/app/data/fichajes.xlsx

# Orígenes CORS permitidos — separados por comas
# En local: http://localhost:3000
# En servidor con IP fija: http://192.168.1.100:3000
CORS_ORIGINS=http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────────────
# URL del backend accesible desde el NAVEGADOR (no desde Docker)
# IMPORTANTE: debe ser la IP/hostname que el navegador del usuario puede alcanzar
# En local: http://localhost:8000
# En TrueNAS con IP 192.168.1.100: http://192.168.1.100:8000
VITE_API_URL=http://localhost:8000
